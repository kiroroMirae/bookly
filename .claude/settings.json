{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(php artisan:*)",
      "Bash(vendor/bin/pint:*)",
      "Bash(php vendor/bin/pint:*)",
      "Bash(vendor/bin/pest:*)",
      "Bash(php artisan test:*)",
      "Bash(composer:*)",
      "Bash(npm:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(ssh:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(rm -rf:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(* > /dev/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "vendor/bin/pint --dirty" }
        ]
      }
    ]
  }
}
